{
  "name": "block-minijava",
  "version": "0.2.0",
  "description": "B-MJ: Block-based MiniJava IDE built with TypeScript, npm, webpack, and Blockly.",
  "private": true,
  "scripts": {
    "build": "webpack --mode=production",
    "serve": "webpack serve --mode=development --open",
    "dev": "webpack serve --mode=development",
    "clean": "rimraf docs",
    "typecheck": "tsc --noEmit",
    "lint": "node test/run_lint.js",
    "test": "npm run test:build && node test/run_roundtrip.js && node test/run_typecheck.js && node test/run_machine.js && node test/run_subst.js && node test/run_eval.js && node test/run_fuzz.js && node test/run_reachability.js && node test/run_gc.js && node test/run_block_colors.js && node test/dist/smoke.bundle.js",
    "test:build": "webpack --config webpack.test.config.js",
    "test:roundtrip": "npm run test:build && node test/run_roundtrip.js",
    "test:typecheck": "npm run test:build && node test/run_typecheck.js",
    "test:machine": "npm run test:build && node test/run_machine.js",
    "test:subst": "npm run test:build && node test/run_subst.js",
    "test:eval": "npm run test:build && node test/run_eval.js",
    "test:fuzz": "npm run test:build && node test/run_fuzz.js",
    "test:reachability": "npm run test:build && node test/run_reachability.js",
    "test:gc": "npm run test:build && node test/run_gc.js",
    "test:block-colors": "npm run test:build && node test/run_block_colors.js",
    "test:smoke": "npm run test:build && node test/dist/smoke.bundle.js",
    "test:ui": "playwright test test/ui/workbench.spec.ts --project=chromium",
    "test:ui:visual": "playwright test test/ui/visual.spec.ts --project=chromium",
    "test:ui:update": "playwright test test/ui/visual.spec.ts --project=chromium --update-snapshots"
  },
  "dependencies": {
    "blockly": "^12.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "rimraf": "^6.0.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1"
  },
  "keywords": [
    "blockly",
    "minijava",
    "typescript",
    "webpack",
    "visual-programming",
    "block-based-programming"
  ],
  "license": "MIT"
}
